{
    "name": "decocode/laravel-mcp",
    "description": "Read-only MCP server for Laravel apps — safe production data diagnostics for Claude (claude.ai + Claude Code).",
    "keywords": ["laravel", "mcp", "model-context-protocol", "diagnostics", "read-only"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "decocode",
            "homepage": "https://decocode.pl"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/mcp": "^0.8",
        "laravel/passport": "^12.0|^13.0",
        "illuminate/console": "^11.45|^12.0|^13.0",
        "illuminate/contracts": "^11.45|^12.0|^13.0",
        "illuminate/database": "^11.45|^12.0|^13.0",
        "illuminate/http": "^11.45|^12.0|^13.0",
        "illuminate/support": "^11.45|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.5|^10.0",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Decocode\\LaravelMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Decocode\\LaravelMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Decocode\\LaravelMcp\\McpServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "prefer-stable": true
}
